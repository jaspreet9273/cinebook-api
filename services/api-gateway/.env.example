# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── JWT (min 32 chars — generate with: openssl rand -hex 32) ─────────────────
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=your_refresh_secret_at_least_32_characters_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Downstream Services ──────────────────────────────────────────────────────
USER_SERVICE_URL=http://localhost:3004
BOOKING_SERVICE_URL=http://localhost:3001
PAYMENT_SERVICE_URL=http://localhost:3002
SHOW_SERVICE_URL=http://localhost:3003

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── CORS (comma-separated) ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Circuit Breaker ──────────────────────────────────────────────────────────
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT_MS=30000

# ─── Proxy ────────────────────────────────────────────────────────────────────
TRUST_PROXY=1