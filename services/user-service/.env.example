# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3004

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/cinebook

# ─── JWT (must match api-gateway values exactly) ──────────────────────────────
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=your_refresh_secret_at_least_32_characters_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
TRUSTED_ORIGINS=http://localhost:3000

# ─── Bcrypt (lower = faster tests, higher = more secure in prod) ──────────────
BCRYPT_ROUNDS=12