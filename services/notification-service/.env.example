# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://admin:password@localhost:5672/cinebook

# ─── Email ────────────────────────────────────────────────────────────────────
# Leave SMTP_USER and SMTP_PASS blank to auto-use Ethereal (dev fake SMTP)
# Preview sent emails at the URL logged to console
# For production use Resend: SMTP_HOST=smtp.resend.com PORT=465 SECURE=true
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@cinebook.app

# ─── SMS (uncomment your provider in src/handlers/smsHandler.ts) ──────────────
# TWILIO_SID=
# TWILIO_TOKEN=
# TWILIO_FROM=
# FAST2SMS_API_KEY=